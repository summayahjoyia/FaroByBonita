<?xml version="1.0" encoding="utf-8"?>
<!--
    Dependent Fragment
    res/layout/dependent_fragment.xml
    Used by: DependentFragment.java
    Hosted in: LoginActivity.java
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <!-- Step indicator -->
        <TextView
            android:id="@+id/tv_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 2"
            android:textColor="@color/grey"
            android:textSize="13sp"
            android:letterSpacing="0.04"
            android:layout_marginTop="52dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Heading -->
        <TextView
            android:id="@+id/tv_dependent_heading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Who are you\ncaring for?"
            android:textColor="@color/black"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_step"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_dependent_sub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="You can add more dependents later."
            android:textColor="@color/grey"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_dependent_heading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Dependent name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_dependent_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Dependent's Name"
            android:layout_marginTop="36dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/grey"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/tv_dependent_sub"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_dependent_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:textColor="@color/black"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Relationship dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_relationship"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Your Relationship"
            android:layout_marginTop="14dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/grey"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/til_dependent_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <AutoCompleteTextView
                android:id="@+id/actv_relationship"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error message -->
        <TextView
            android:id="@+id/tv_dependent_error"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#D93025"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/til_relationship"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Continue button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="Continue"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:letterSpacing="0.02"
            android:layout_marginTop="24dp"
            app:backgroundTint="@color/black"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_dependent_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Loading spinner -->
        <ProgressBar
            android:id="@+id/progress_dependent"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/btn_continue"
            app:layout_constraintBottom_toBottomOf="@id/btn_continue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Add another dependent prompt -->
        <LinearLayout
            android:id="@+id/ll_add_another"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btn_continue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Caring for more than one? "
                android:textColor="@color/grey"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_add_another"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add another"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
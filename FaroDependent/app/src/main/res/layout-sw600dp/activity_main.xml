<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF8">

    <!-- Date -->
    <TextView
        android:id="@+id/dateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monday, March 8"
        android:textSize="36sp"
        android:textColor="#1D1D1F"
        android:fontFamily="serif"
        android:letterSpacing="0.02"
        android:layout_marginStart="64dp"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Year -->
    <TextView
        android:id="@+id/yearText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2026"
        android:textSize="24sp"
        android:textColor="#8A8A8E"
        android:fontFamily="serif"
        android:layout_marginStart="64dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/dateText"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Reminder -->
    <TextView
        android:id="@+id/reminderText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="You are safe at home."
        android:textSize="28sp"
        android:textColor="#3A3A3C"
        android:fontFamily="serif"
        android:lineSpacingExtra="6dp"
        android:layout_marginStart="64dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="64dp"
        app:layout_constraintTop_toBottomOf="@id/yearText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Visitor name (hidden by default) -->
    <TextView
        android:id="@+id/visitorName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stacy is here"
        android:textSize="40sp"
        android:textColor="#1D1D1F"
        android:fontFamily="serif"
        android:alpha="0"
        android:layout_marginStart="64dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/yearText"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Visitor photo (hidden by default) -->
    <ImageView
        android:id="@+id/visitorPhoto"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:scaleType="centerCrop"
        android:alpha="0"
        android:layout_marginEnd="64dp"
        android:background="#E8E8ED"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
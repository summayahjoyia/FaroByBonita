<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_delete_reminder.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="40dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_delete_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This cannot be undone."
        android:textColor="@color/grey"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- Confirm delete -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_delete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Delete"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:layout_marginBottom="10dp"
        app:backgroundTint="#D93025"
        app:cornerRadius="12dp"
        app:elevation="0dp" />

    <!-- Cancel -->
    <com.google.android.material.button.MaterialButton
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:id="@+id/btn_cancel_delete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Cancel"
        android:textColor="@color/black"
        android:textSize="15sp"
        app:strokeColor="@color/grey"
        app:cornerRadius="12dp" />

</LinearLayout>